#!/usr/bin/env zsh
set -euo pipefail

find_sidebar_pane() {
  tmux list-panes -F '#{pane_id} #{pane_at_left} #{pane_current_command}' \
    | awk '$2=="1" && $3=="workmux" {print $1; exit}'
}

sidebar_enabled=$(tmux show-option -gqv @workmux_sidebar_enabled)
sidebar_pane=$(find_sidebar_pane)
current_pane=$(tmux display-message -p '#{pane_id}')

if [[ "$sidebar_enabled" != "1" ]]; then
  mise x -- workmux sidebar
  sidebar_pane=$(find_sidebar_pane)
  [[ -n "$sidebar_pane" ]] && tmux select-pane -t "$sidebar_pane"
elif [[ "$sidebar_pane" == "$current_pane" ]]; then
  mise x -- workmux sidebar
else
  [[ -n "$sidebar_pane" ]] && tmux select-pane -t "$sidebar_pane"
fi
