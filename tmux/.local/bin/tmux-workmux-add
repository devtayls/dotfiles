#!/usr/bin/env zsh
set -euo pipefail

# Base on main by default; --here uses the current branch instead.
use_main=1
for arg in "$@"; do
  case "$arg" in
    --here) use_main=0 ;;
  esac
done

worktree_name=$(mise x -- gum input --placeholder="Worktree name...") || exit 0
[[ -z "$worktree_name" ]] && exit 0

worktree_name="${(L)worktree_name// /-}"

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  mise x -- gum style --foreground="red" "Not in a git repository"
  exit 1
fi

if (( use_main )); then
  mise x -- workmux add --base main "$worktree_name"
else
  mise x -- workmux add "$worktree_name"
fi
