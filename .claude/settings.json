{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); [[ \"$CLAUDE_PROJECT_DIR\" = \"$HOME/dotfiles\" && \"$f\" = \"$HOME/dotfiles/\"* ]] && r=\"${f#$HOME/dotfiles/}\" && [[ \"$r\" = */* && \"$r\" != .claude/* && \"$r\" != .git/* && \"$r\" != .github/* ]] && \"$HOME/.local/bin/dots\" stow >/dev/null 2>&1; exit 0"
          }
        ]
      }
    ]
  }
}
